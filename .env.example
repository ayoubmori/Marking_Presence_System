APP_NAME=Flexible Presence API
DATABASE_URL=sqlite:///./presence.db
SECRET_KEY=change-this-secret-key

QR_TOKEN_TTL_SECONDS=10

FACE_AUTO_ACCEPT_THRESHOLD=0.85
FACE_QR_FALLBACK_THRESHOLD=0.60

DEFAULT_PRESENCE_MODE=checkin_only

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

CAMERA_ID=usb-cam-1

MOCK_FACE_MODE=always_qr
MOCK_FACE_CANDIDATE_USER_ID=EMP001

DEBUG_SAVE_EMAIL_TO_DISK=true
DEBUG_OUTBOX_DIR=./debug_outbox

ENABLE_TEST_ENDPOINTS=true
